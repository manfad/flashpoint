{
  "name": "flashpoint",
  "displayName": "Flashpoint",
  "description": "Anchors around AI agent edits: inspect diffs and timetravel back without touching your git history. No timeline is ever lost.",
  "version": "0.2.0",
  "publisher": "manfad",
  "repository": {
    "type": "git",
    "url": "https://github.com/manfad/flashpoint.git"
  },
  "icon": "media/icon.png",
  "keywords": ["flashpoint", "checkpoint", "ai", "agent", "cursor", "claude", "codex", "timetravel", "snapshot", "jj"],
  "engines": { "vscode": "^1.80.0" },
  "categories": ["SCM Providers", "AI", "Other"],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onView:flashpoint.tree",
    "onView:flashpoint.timeline"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "flashpoint", "title": "Flashpoint", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "flashpoint": [
        { "id": "flashpoint.tree", "name": "Agent Session" },
        { "id": "flashpoint.timeline", "name": "Timeline", "type": "webview" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "flashpoint.tree",
        "contents": "The `fp` binary was not found.\n\n[Set up Flashpoint](command:flashpoint.setup)\n\nSetup helps install `fp` (npm), then asks which AI agents you use and wires their checkpoint hooks. Set `flashpoint.binary` if you install somewhere custom.\n\n[Install instructions](https://github.com/manfad/flashpoint)\n\n[Re-check](command:flashpoint.recheck)",
        "when": "flashpoint.fpMissing"
      }
    ],
    "commands": [
      { "command": "flashpoint.refresh", "title": "Flashpoint: Refresh", "icon": "$(refresh)" },
      { "command": "flashpoint.anchor", "title": "Flashpoint: Anchor (save safe point)", "icon": "$(shield)" },
      { "command": "flashpoint.timetravel", "title": "Flashpoint: Timetravel…", "icon": "$(history)" },
      { "command": "flashpoint.openDiff", "title": "Flashpoint: Open Diff" },
      { "command": "flashpoint.compareCurrent", "title": "Flashpoint: Compare With Current", "icon": "$(diff)" },
      { "command": "flashpoint.timelinePrime", "title": "Flashpoint: Make Prime Timeline", "icon": { "light": "media/crown-light.svg", "dark": "media/crown.svg" } },
      { "command": "flashpoint.timelineTravel", "title": "Flashpoint: Travel To Selected Anchor", "icon": "$(history)" },
      { "command": "flashpoint.status", "title": "Flashpoint: Status" },
      { "command": "flashpoint.recheck", "title": "Flashpoint: Re-check fp binary" },
      { "command": "flashpoint.setup", "title": "Flashpoint: Setup (install fp + wire agent hooks)", "icon": "$(tools)" },
      { "command": "flashpoint.check", "title": "Flashpoint: Check Setup" }
    ],
    "menus": {
      "view/title": [
        { "command": "flashpoint.anchor", "when": "view == flashpoint.tree", "group": "navigation@1" },
        { "command": "flashpoint.refresh", "when": "view == flashpoint.tree", "group": "navigation@2" },
        { "command": "flashpoint.timelinePrime", "when": "view == flashpoint.timeline && flashpoint.timelineAnchorSelected", "group": "navigation@1" },
        { "command": "flashpoint.timelineTravel", "when": "view == flashpoint.timeline && flashpoint.timelineAnchorSelected", "group": "navigation@2" },
        { "command": "flashpoint.refresh", "when": "view == flashpoint.timeline", "group": "navigation@3" }
      ],
      "view/item/context": [
        { "command": "flashpoint.timetravel", "when": "view == flashpoint.tree && viewItem =~ /^checkpoint/", "group": "inline@1" },
        { "command": "flashpoint.compareCurrent", "when": "view == flashpoint.tree && viewItem =~ /^checkpoint/", "group": "inline@2" }
      ]
    },
    "configuration": {
      "title": "Flashpoint",
      "properties": {
        "flashpoint.binary": {
          "type": "string",
          "default": "fp",
          "description": "Path to the fp binary (default: fp on PATH; ~/.cargo/bin and ~/.local/bin are also probed)."
        },
        "flashpoint.pollSeconds": {
          "type": "number",
          "default": 2,
          "description": "How often to poll the store for changes while the view is visible."
        }
      }
    }
  }
}
